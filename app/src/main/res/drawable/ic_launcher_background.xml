<?xml version="1.0" encoding="utf-8"?>
<!-- Aurora gradient plate for the adaptive launcher icon. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="6" android:startY="0"
                android:endX="102" android:endY="108">
                <item android:offset="0.0" android:color="#FF6366F1" />
                <item android:offset="0.52" android:color="#FF8B5CF6" />
                <item android:offset="1.0" android:color="#FFEC4899" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- soft light glow in the upper-left for depth -->
    <path android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="34" android:centerY="30"
                android:gradientRadius="72">
                <item android:offset="0.0" android:color="#40FFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
