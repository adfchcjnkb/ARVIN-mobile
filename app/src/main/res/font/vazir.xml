<?xml version="1.0" encoding="utf-8"?>
<!--
    Vazirmatn font family (SIL Open Font License) — used for Persian & Arabic locales.
    Download vazir_regular.ttf and vazir_medium.ttf from the official Vazirmatn releases
    and place them in this same res/font/ folder before building. See README.md.
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:font="@font/vazir_regular"
        android:fontStyle="normal"
        android:fontWeight="400" />
    <font
        android:font="@font/vazir_medium"
        android:fontStyle="normal"
        android:fontWeight="500" />
</font-family>
